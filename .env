# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:1234@localhost:1234/Steward

# Flask Secret Key
SECRET_KEY=your-secret-key-here-change-this-in-production

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234

# SMS Configuration
SMS_PROVIDER=mock
# Change to 'africastalking' or 'twilio' when you have API keys
SMS_API_KEY=your-api-key-here
SMS_USERNAME=sandbox
SMS_SENDER_ID=Stewardship

# Twilio (if using)
TWILIO_ACCOUNT_SID=your-account-sid-here
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# Flask Environment
FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=1